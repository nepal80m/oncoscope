# Oncoscope frontend env — copy to .env and fill in.
# Reads come from the public GCS bucket; writes go to Firestore.

# Public GCS bucket holding the slide artifacts (manifest, result.json, DZI, …)
VITE_GCS_BASE=https://storage.googleapis.com/oncoscope-1

# Firebase web config — from Firebase console → Project settings → Your apps → Web.
# The apiKey is public by design (access is controlled by Firestore security rules).
VITE_FB_API_KEY=your-web-api-key
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_PROJECT_ID=your-project-id
VITE_FB_SENDER_ID=000000000000
VITE_FB_APP_ID=1:000000000000:web:xxxxxxxxxxxx
# Firestore database id — "(default)" unless you created a named database
VITE_FB_DB_ID=(default)
